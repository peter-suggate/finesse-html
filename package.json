{
  "name": "finesse-html",
  "displayName": "Finesse",
  "description": "Edit rendered HTML on the fly while preserving your source.",
  "version": "0.0.1",
  "publisher": "peter-suggate",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "dist/host/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/peter-suggate/finesse-html.git"
  },
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onCommand:finesse.openPreview",
    "onCommand:finesse.openDevServerPreview",
    "onCommand:finesse.connectCursorAgent",
    "onCommand:finesse.disconnectCursorAgent",
    "onCommand:finesse.cursorAgentStatus",
    "onCommand:finesse.connectClaudeAgent",
    "onCommand:finesse.disconnectClaudeAgent",
    "onCommand:finesse.claudeAgentStatus",
    "onCommand:finesse.selectAgentProvider"
  ],
  "contributes": {
    "commands": [
      {
        "command": "finesse.openPreview",
        "title": "Open Preview",
        "category": "Finesse",
        "icon": "$(open-preview)"
      },
      {
        "command": "finesse.openDevServerPreview",
        "title": "Open Dev Server Preview",
        "category": "Finesse"
      },
      {
        "command": "finesse.closePreview",
        "title": "Close Preview",
        "category": "Finesse"
      },
      {
        "command": "finesse.editAnyway",
        "title": "Edit Templated File Anyway",
        "category": "Finesse"
      },
      {
        "command": "finesse.connectCursorAgent",
        "title": "Connect Cursor Agent",
        "category": "Finesse"
      },
      {
        "command": "finesse.disconnectCursorAgent",
        "title": "Disconnect Cursor Agent",
        "category": "Finesse"
      },
      {
        "command": "finesse.cursorAgentStatus",
        "title": "Show Cursor Agent Connection Status",
        "category": "Finesse"
      },
      {
        "command": "finesse.connectClaudeAgent",
        "title": "Connect Claude Code",
        "category": "Finesse"
      },
      {
        "command": "finesse.disconnectClaudeAgent",
        "title": "Disconnect Claude Code",
        "category": "Finesse"
      },
      {
        "command": "finesse.claudeAgentStatus",
        "title": "Show Claude Code Connection Status",
        "category": "Finesse"
      },
      {
        "command": "finesse.selectAgentProvider",
        "title": "Select Agent Provider",
        "category": "Finesse"
      }
    ],
    "configuration": {
      "title": "Finesse",
      "properties": {
        "finesse.port": {
          "type": [
            "number",
            "string"
          ],
          "default": "auto",
          "markdownDescription": "HTTP server port. Use `\"auto\"` to allocate an ephemeral port, or a specific port number."
        },
        "finesse.editableElements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Override block-container selector list. Empty = use computed defaults."
        },
        "finesse.templateTokens": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "\\{\\{[^}]*\\}\\}",
            "\\{%[^%]*%\\}",
            "<%[^%]*%>",
            "<\\?[^?]*\\?>"
          ],
          "description": "Regex source patterns marking the whole file as templated. JS template-literal `${...}` interpolations are always handled at the per-text-node level and don't lock the file."
        },
        "finesse.serverIdleTimeout": {
          "type": "number",
          "default": 60000,
          "description": "Milliseconds to keep the preview server alive after the last preview closes."
        },
        "finesse.reloadDebounceMs": {
          "type": "number",
          "default": 150,
          "description": "Debounce window (ms) for external-edit reload triggers."
        },
        "finesse.openOnHtmlOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the preview when an HTML file is opened."
        },
        "finesse.reactDevServerUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "React or Next dev server URL to proxy for JSX/TSX previews, for example `http://localhost:5173` or `http://localhost:3000/dashboard`. Use the exact page URL for Next apps, and enable `jsx-loc-plugin` so Finesse can map rendered DOM back to JSX source."
        },
        "finesse.aiCommand": {
          "type": "string",
          "default": "",
          "description": "Command id to invoke for \"Rewrite with AI\" (Phase 3A). Empty = auto-detect at activation."
        },
        "finesse.agent.cursorModel": {
          "type": "string",
          "default": "composer-2",
          "description": "Cursor model id to use when asking an agent to change the selected element."
        },
        "finesse.agent.claudeModel": {
          "type": "string",
          "default": "claude-opus-4-8",
          "description": "Claude model id (e.g. claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5, claude-fable-5, or alias 'opus'/'sonnet'/'haiku') used by the Claude Code agent provider. Also changeable from the Ask Agent panel's ⋯ menu."
        },
        "finesse.agent.provider": {
          "type": "string",
          "enum": [
            "cursor",
            "claude-code"
          ],
          "enumDescriptions": [
            "Use the Cursor Agent SDK (requires a Cursor API key).",
            "Use Claude Code via the Claude Agent SDK (uses your local Claude Code subscription if authenticated)."
          ],
          "default": "cursor",
          "description": "Which agent runs when you press Send in the Ask Agent panel."
        }
      }
    },
    "keybindings": [
      {
        "command": "finesse.openPreview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorTextFocus && (editorLangId == html || editorLangId == javascriptreact || editorLangId == typescriptreact || editorLangId == javascript || editorLangId == typescript)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "finesse.openPreview",
          "group": "navigation",
          "when": "resourceLangId == html || resourceExtname == .jsx || resourceExtname == .tsx"
        }
      ],
      "editor/context": [
        {
          "command": "finesse.openPreview",
          "group": "navigation",
          "when": "resourceLangId == html"
        }
      ],
      "explorer/context": [
        {
          "command": "finesse.openPreview",
          "group": "navigation",
          "when": "resourceExtname == .html || resourceExtname == .htm"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.iframe.json --noEmit && tsc -p tsconfig.webview.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:watch": "vitest",
    "package": "vsce package --out finesse-html.vsix",
    "clean": "rimraf dist *.vsix"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.139",
    "@cursor/sdk": "^1.0.12"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^2.27.0",
    "esbuild": "^0.20.2",
    "eslint": "^9.0.0",
    "ovsx": "^0.9.1",
    "parse5": "^7.1.2",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.5",
    "ws": "^8.18.0"
  }
}
