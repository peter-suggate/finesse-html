{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "dist/host",
    "rootDir": "src",
    "resolveJsonModule": true,
    "types": ["node", "vscode"]
  },
  "include": ["src/host/**/*", "src/shared/**/*"]
}
